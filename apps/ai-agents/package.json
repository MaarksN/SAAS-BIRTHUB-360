{
  "name": "ai-agents",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/worker.js",
    "start:py": "uvicorn main:app --host 0.0.0.0 --port 8000",
    "dev": "concurrently -n \"worker,api\" -c \"blue,green\" \"tsx watch src/worker.ts\" \"uvicorn main:app --reload\"",
    "dev:py": "uvicorn main:app --reload",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint .",
    "test": "vitest"
  },
  "dependencies": {
    "@salesos/core": "*",
    "@salesos/queue-core": "*",
    "cheerio": "^1.0.0-rc.12",
    "puppeteer": "^21.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "vitest": "^0.34.0"
  }
}
