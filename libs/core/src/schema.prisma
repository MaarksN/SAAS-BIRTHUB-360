generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model Organization {
  id                 String            @id @default(uuid())
  name               String
  stripeCustomerId   String?
  subscriptionStatus String? // active, past_due, canceled, trialing, incomplete_expired
  currentPeriodEnd   DateTime?
  planId             String?
  plan               SubscriptionPlan? @relation(fields: [planId], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  users              User[]
  leads              Lead[]
  usageLogs          UsageLog[]
  creditTransactions CreditTransaction[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  emailAccounts      EmailAccount[]
  campaigns          Campaign[]
  scheduledEmails    ScheduledEmail[]

  @@map("organizations")
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  actorId        String?      // User ID or System
  action         String
  entity         String
  entityId       String
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  // No updatedAt or deletedAt - Immutable

  @@index([organizationId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  role           Role         @default(MEMBER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([email])
  deals          Deal[]
  usageLogs      UsageLog[]
  aiFeedback     AiFeedback[]
  notifications  Notification[]
  campaigns      Campaign[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("users")
}

model Notification {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String       // INFO, SUCCESS, WARNING, ERROR
  content        Json         // Rich content structure
  link           String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  deletedAt      DateTime?

  @@index([userId, readAt])
  @@map("notifications")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@map("permissions")
}

// LDR - Market Intelligence Models

model CompanyProfile {
  id             String   @id @default(cuid())
  cnpj           String   @unique
  name           String
  segment        String?
  cnae           String?
  employeesCount Int?
  foundedAt      DateTime?
  isActive       Boolean  @default(true)
  enrichmentLogs EnrichmentLog[]
  reliability    DataReliabilityScore?
  buyingCommittees BuyingCommittee[]
  deals          Deal[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@map("company_profiles")
}

model EnrichmentLog {
  id              String         @id @default(cuid())
  companyId       String
  company         CompanyProfile @relation(fields: [companyId], references: [id])
  source          String
  dataField       String
  previousValue   String?
  newValue        String?
  confidenceScore Float
  performedAt     DateTime       @default(now())
  deletedAt       DateTime?

  @@map("enrichment_logs")
}

model DataReliabilityScore {
  id        String         @id @default(cuid())
  companyId String         @unique
  company   CompanyProfile @relation(fields: [companyId], references: [id])
  score     Float          // 0 to 100
  factors   Json           // Detailed breakdown of factors
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  @@map("data_reliability_scores")
}

// BDR - Outbound Hunter Models

model BuyingCommittee {
  id             String   @id @default(cuid())
  companyId      String
  company        CompanyProfile @relation(fields: [companyId], references: [id])
  contacts       Contact[]
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@map("buying_committees")
}

model Contact {
  id                String          @id @default(cuid())
  name              String
  email             String?
  phone             String?
  role              String?
  seniority         String?         // C-Level, VP, Director, Manager
  buyingCommitteeId String?
  buyingCommittee   BuyingCommittee? @relation(fields: [buyingCommitteeId], references: [id])

  @@index([email])
  @@index([buyingCommitteeId])
  linkedInUrl       String?
  isDecisionMaker   Boolean         @default(false)
  influenceLevel    String?         // High, Medium, Low
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  @@map("contacts")
}

model OutboundSequence {
  id          String   @id @default(cuid())
  name        String
  steps       Json
  targetAudience Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@map("outbound_sequences")
}

// SDR - Inbound Response Models

model Lead {
  id             String   @id @default(cuid())
  email          String
  name           String?
  phone          String?
  companyName    String?
  score          Float    @default(0)
  status         String   @default("NEW") // NEW, QUALIFIED, DISQUALIFIED
  linkedInUrl    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  leadScores     LeadScore[]
  scheduledEmails ScheduledEmail[]

  @@unique([email, organizationId])
  @@index([organizationId, status])
  @@index([linkedInUrl])
  @@map("leads")
}

model LeadScore {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  score     Float
  reason    String
  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@map("lead_scores")
}

model Cadence {
  id        String   @id @default(cuid())
  name      String
  steps     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("cadences")
}

// AE - Closer Models

model Deal {
  id             String   @id @default(cuid())
  title          String
  value          Float
  stage          String   // Discovery, Demo, Negotiation, Closed Won, Closed Lost
  probability    Float    // 0-100
  expectedCloseDate DateTime?
  companyId      String
  company        CompanyProfile @relation(fields: [companyId], references: [id])
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([stage])
  @@index([companyId])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  quotes         Quote[]
  meetings       Meeting[]

  @@map("deals")
}

model Quote {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id])
  amount    Float
  status    String   // DRAFT, SENT, ACCEPTED, REJECTED
  version   Int      @default(1)
  content   Json     // Line items, terms
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("quotes")
}

model Meeting {
  id        String   @id @default(cuid())
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  title     String
  startTime DateTime
  endTime   DateTime
  summary   String?
  recordingUrl String?
  analysis  Json?    // AI analysis result
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("meetings")
}

// FinOps & Governance Models

model SubscriptionPlan {
  id            String         @id @default(cuid())
  name          String         @unique
  limits        Json // { "max_leads": 1000, "ai_tokens": 50000, "features": [...] }
  priceMonthly  Decimal
  priceYearly   Decimal
  isActive      Boolean        @default(true)
  organizations Organization[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@map("subscription_plans")
}

model UsageLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  modelUsed      String
  inputTokens    Int
  outputTokens   Int
  cachedTokens   Int          @default(0)
  latencyMs      Int
  estimatedCost  Decimal      @db.Decimal(10, 6)
  contextType    String
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([createdAt])
  @@map("usage_logs")
}

model CreditTransaction {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  amount         Decimal      @db.Decimal(10, 2)
  type           String // 'DEBIT', 'CREDIT', 'REFUND', 'EXPIRATION'
  description    String
  balanceAfter   Decimal      @db.Decimal(10, 2)
  referenceId    String?
  expirationDate DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("credit_transactions")
}

model AiFeedback {
  id        String   @id @default(cuid())
  prompt    String
  response  String
  rating    Boolean // true = thumbs up, false = thumbs down
  reason    String?
  model     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("ai_feedback")
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  status         String   // DRAFT, SCHEDULED, RUNNING, PAUSED, COMPLETED, ARCHIVED
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  creatorId      String
  creator        User     @relation(fields: [creatorId], references: [id])
  audiences      Json?    // Target audience definition
  schedule       Json?    // Schedule definition
  stats          Json?    // Aggregated stats (sent, opened, clicked, replied, bounced)
  scheduledEmails ScheduledEmail[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([organizationId])
  @@map("campaigns")
}

model EmailAccount {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  provider       String   // GMAIL, OUTLOOK, SMTP, RESEND
  email          String
  credentials    Json     // Encrypted tokens or password
  dailyLimit     Int      @default(50)
  usedToday      Int      @default(0)
  stats          Json?    // Reputation stats
  isActive       Boolean  @default(true)
  scheduledEmails ScheduledEmail[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([organizationId])
  @@map("email_accounts")
}

model ScheduledEmail {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id])
  leadId         String?
  lead           Lead?    @relation(fields: [leadId], references: [id])
  senderId       String?
  sender         EmailAccount? @relation(fields: [senderId], references: [id])

  to             String
  subject        String
  body           String

  status         String   // PENDING, QUEUED, SENT, FAILED, CANCELLED
  sendAt         DateTime
  sentAt         DateTime?
  error          String?

  trackingId     String?  // For pixel tracking

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([organizationId])
  @@index([status, sendAt])
  @@index([leadId])
  @@map("scheduled_emails")
}
