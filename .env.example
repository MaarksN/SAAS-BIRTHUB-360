# Database Configuration
# PostgreSQL connection string (e.g., postgres://user:password@localhost:5432/dbname)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/salesos"

# Redis Configuration
# Redis connection string (e.g., redis://localhost:6379)
REDIS_URL="redis://localhost:6379"

# Environment Setup
# Options: development, test, production
NODE_ENV="development"
PORT=3000

# Authentication (NextAuth.js)
# Generate a secret with `openssl rand -base64 32`
NEXTAUTH_SECRET="super-secret-key-change-me"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="super-secret-jwt-key-change-me"

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# AI Service Providers
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# Payment & Billing (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email Service (Resend)
RESEND_API_KEY="re_..."
DEFAULT_FROM_EMAIL="onboarding@resend.dev"

# CRM Integration (HubSpot)
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# Logging
# Options: debug, info, warn, error
LOG_LEVEL="debug"

# Admin Initial Setup
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="password123"

# CI/CD Flags
# Set to "true" to skip validation during Docker builds
SKIP_ENV_VALIDATION="false"
