{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "SKIP_ENV_VALIDATION",
    "NODE_ENV",
    "NEXT_PUBLIC_*",
    "RESEND_API_KEY",
    "STRIPE_SECRET_KEY",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL"
  ],
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".next/**"],
      "dependsOn": ["^build"]
    },
    "lint": {},
    "type-check": {},
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
