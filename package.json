{
  "name": "salesos-ultimate",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/manager.mjs setup",
    "dev": "node scripts/manager.mjs dev",
    "build": "node scripts/manager.mjs build",
    "test": "vitest run",
    "lint": "npx turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "deploy:legacy": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy.ps1",
    "prepare": "husky",
    "migrate": "bash scripts/migrate.sh",
    "deploy": "bash scripts/docker-deploy.sh",
    "health": "bash scripts/health-check.sh",
    "workers:restart": "bash scripts/restart-workers.sh",
    "cleanup": "bash scripts/cleanup.sh",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "npx prisma studio --schema=packages/database/prisma/schema.prisma",
    "db:reset": "npx prisma migrate reset --schema=packages/database/prisma/schema.prisma",
    "test:coverage": "npx vitest run --coverage",
    "ai:dev": "cd apps/ai-agents && uvicorn main:app --reload",
    "workers": "npm run workers:all --workspace=libs/queue-core"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@jridgewell/resolve-uri": "^3.1.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/pdfkit": "^0.17.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "glob": "^13.0.3",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.0",
    "prisma": "^5.21.0",
    "rollup": "^4.57.1",
    "semantic-release": "^23.0.0",
    "syncpack": "^12.0.0",
    "turbo": "^2.8.9",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@prisma/client": "^5.21.0",
    "date-fns": "^4.1.0",
    "fs-extra": "^11.3.3",
    "pdfkit": "^0.17.2",
    "tsx": "^4.21.0"
  }
}
